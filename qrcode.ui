<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 1.0 -->
<interface>
  <!-- interface-name qrcode.ui -->
  <requires lib="gtk" version="4.18"/>
  <object class="GtkApplicationWindow" id="appwindow">
    <property name="title">QRCode Generator</property>
    <child>
      <object class="GtkBox">
        <property name="homogeneous">True</property>
        <property name="margin-bottom">10</property>
        <property name="margin-end">10</property>
        <property name="margin-start">10</property>
        <property name="margin-top">10</property>
        <property name="spacing">5</property>
        <child>
          <object class="GtkBox" id="box1">
            <property name="orientation">vertical</property>
            <property name="spacing">5</property>
            <property name="valign">start</property>
            <child>
              <object class="GtkBox">
                <property name="homogeneous">True</property>
                <child>
                  <object class="GtkLabel" id="data_lbl">
                    <property name="label">Data</property>
                    <property name="width-chars">10</property>
                  </object>
                </child>
                <child>
                  <object class="GtkEntry" id="data_txt"/>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkBox">
                <property name="homogeneous">True</property>
                <child>
                  <object class="GtkLabel" id="size_lbl">
                    <property name="label">Size</property>
                    <property name="width-chars">10</property>
                  </object>
                </child>
                <child>
                  <object class="GtkEntry" id="size_txt">
                    <property name="text">10</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkBox" id="">
                <property name="homogeneous">True</property>
                <child>
                  <object class="GtkLabel" id="border_lbl">
                    <property name="label">Border</property>
                    <property name="width-chars">10</property>
                  </object>
                </child>
                <child>
                  <object class="GtkEntry" id="border_txt">
                    <property name="text">2</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkBox">
                <property name="homogeneous">True</property>
                <child>
                  <object class="GtkLabel" id="correction_lbl">
                    <property name="label">Error Correction</property>
                  </object>
                </child>
                <child>
                  <object class="GtkComboBox" id="err_correction_combo"/>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkBox">
                <property name="homogeneous">True</property>
                <child>
                  <object class="GtkLabel">
                    <property name="label">Fill Color</property>
                  </object>
                </child>
                <child>
                  <object class="GtkColorDialogButton" id="fill_color_button">
                    <property name="rgba">rgb(0,0,0)</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkBox">
                <property name="homogeneous">True</property>
                <child>
                  <object class="GtkLabel">
                    <property name="label">Back Color</property>
                  </object>
                </child>
                <child>
                  <object class="GtkColorDialogButton" id="back_color_button">
                    <property name="rgba">rgb(255,255,255)</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkBox">
                <property name="homogeneous">True</property>
                <child>
                  <object class="GtkLabel" id="download_lbl">
                    <property name="label">QRCode</property>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="download_btn">
                    <property name="label">Download</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkBox">
                <property name="homogeneous">True</property>
                <property name="spacing">5</property>
                <child>
                  <object class="GtkButton" id="clear_btn">
                    <property name="label">Clear</property>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="gen_btn">
                    <property name="label">Generate</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkImage" id="qrcode_display">
            <property name="height-request">200</property>
            <property name="hexpand">True</property>
            <property name="icon-size">large</property>
            <property name="pixel-size">200</property>
            <property name="vexpand">True</property>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
